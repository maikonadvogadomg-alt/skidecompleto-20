{
  "expo": {
    "name": "AppIDE",
    "slug": "app-ide",
    "version": "2.9.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "appide",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.devmobile.ide"
    },
    "android": {
      "package": "com.devmobile.ide",
      "versionCode": 43,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0d1117"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "owner": "maikon12",
    "extra": {
      "eas": {
        "projectId": "57007145-e348-4887-84e6-3c20644f5ec4"
      },
      "router": {}
    }
  }
}
