# ──────────────────────────────────────────────────────────────────────────────
# DevMobile — Variáveis de ambiente completas (copie para .env)
# NUNCA commite o .env — contém segredos
# ──────────────────────────────────────────────────────────────────────────────

# ── Modo de execução do app ───────────────────────────────────────────────────
# offline   → sem backend (somente editor + IA direta)
# local     → API rodando localmente no dispositivo
# termux    → API via Termux no Android
# remote    → API em servidor externo
EXPO_PUBLIC_APP_MODE=offline

# ── Estratégia de API ─────────────────────────────────────────────────────────
# offline        → não usa backend
# local-device   → API em 127.0.0.1:<LOCAL_API_PORT>
# termux         → API via Termux
# remote-custom  → URL personalizada abaixo
EXPO_PUBLIC_API_STRATEGY=offline

# URL base fixa da API (sobrepõe tudo acima se preenchida)
# EXPO_PUBLIC_API_BASE_URL=https://meu-servidor.com/api

# URL da API remota (usada quando strategy=remote-custom)
# EXPO_PUBLIC_REMOTE_API_URL=https://meu-servidor.com/api

# ── Portas locais ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_LOCAL_API_PORT=18115
EXPO_PUBLIC_LOCAL_PREVIEW_PORT=8080

# ── Funcionalidades ───────────────────────────────────────────────────────────
EXPO_PUBLIC_ENABLE_TERMUX=false
EXPO_PUBLIC_ENABLE_REMOTE_AI=true
EXPO_PUBLIC_ENABLE_GITHUB=true
EXPO_PUBLIC_ENABLE_REMOTE_DB=true
EXPO_PUBLIC_ENABLE_REMOTE_TERMINAL=false

# ── Chaves de IA direta (sem servidor) ───────────────────────────────────────
# O app detecta automaticamente o provedor pelo prefixo da chave
# Google Gemini (grátis): https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_KEY=AIzaSy...

# Groq (grátis, muito rápido): https://console.groq.com
EXPO_PUBLIC_GROQ_KEY=gsk_...

# OpenAI: https://platform.openai.com
EXPO_PUBLIC_OPENAI_KEY=sk-...

# Anthropic Claude: https://console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_KEY=sk-ant-...

# OpenRouter (acesso a 200+ modelos): https://openrouter.ai
EXPO_PUBLIC_OPENROUTER_KEY=sk-or-...

# xAI / Grok: https://console.x.ai
EXPO_PUBLIC_XAI_KEY=xai-...

# Perplexity (busca na internet): https://perplexity.ai/settings/api
EXPO_PUBLIC_PERPLEXITY_KEY=pplx-...

# ── Banco de Dados Neon (Postgres gratuito) ───────────────────────────────────
# Obtenha grátis em: https://neon.tech
# Formato completo:
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Ou separado:
NEON_HOST=ep-xxxxx.us-east-2.aws.neon.tech
NEON_DATABASE=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=SuaSenhaAqui
NEON_PORT=5432
NEON_SSL=true

# ── Segurança / Auth ──────────────────────────────────────────────────────────
# Gerar salt: node -e "require('bcrypt').genSalt(12, (e,s)=>console.log(s))"
BCRYPT_SALT_ROUNDS=12

# JWT secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=mude_isso_para_um_segredo_longo_64_chars_minimo

# Session secret
SESSION_SECRET=outro_segredo_para_sessoes

# ── GitHub ────────────────────────────────────────────────────────────────────
# Token pessoal: https://github.com/settings/tokens
EXPO_PUBLIC_GITHUB_TOKEN=ghp_...
EXPO_PUBLIC_GITHUB_USER=seu_usuario

# ── EAS Build ─────────────────────────────────────────────────────────────────
# Token EAS: https://expo.dev/accounts/[user]/settings/access-tokens
EXPO_TOKEN=seu_expo_token_aqui
